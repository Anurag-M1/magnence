# Database & Cache
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/magnence"
REDIS_URL="redis://localhost:6379"

# Supabase (replaces AWS for storage + optional pg managed db)
SUPABASE_URL="https://your-project-id.supabase.co"
SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
SUPABASE_STORAGE_BUCKET="magnence-files"

# Auth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-strong-secret"
JWT_ACCESS_SECRET="replace-with-access-secret"
JWT_REFRESH_SECRET="replace-with-refresh-secret"
JWT_REFRESH_TTL_DAYS="7"
PII_ENCRYPTION_KEY="replace-with-32+-char-encryption-key"
GOOGLE_CLIENT_ID="google-client-id"
GOOGLE_CLIENT_SECRET="google-client-secret"

# Email
RESEND_API_KEY="re_xxxxx"
EMAIL_FROM="hello@yourdomain.com"

# Payments
STRIPE_SECRET_KEY="sk_test_xxx"
STRIPE_WEBHOOK_SECRET="whsec_xxx"

# WhatsApp
WHATSAPP_TOKEN="token"
WHATSAPP_PHONE_ID="phone-id"
WHATSAPP_VERIFY_TOKEN="verify-token"
WHATSAPP_APP_SECRET="whatsapp-app-secret"

# Calendly
CALENDLY_WEBHOOK_SIGNING_KEY="calendly-signing-key"

# CAPTCHA
TURNSTILE_SECRET_KEY="turnstile-secret-key"

# Monitoring
SENTRY_DSN="https://example@sentry.io/project"
POSTHOG_KEY="phc_xxx"

# AI
OPENAI_API_KEY="sk-xxxx"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_API_URL="http://localhost:4000"
NODE_ENV="development"
